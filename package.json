{
  "name": "feishu-user-plugin",
  "version": "1.0.1",
  "description": "All-in-one Feishu plugin for Claude Code — send messages as yourself, read chats, manage docs/tables/wiki. 33 tools + 9 skills, 3 auth layers.",
  "main": "src/index.js",
  "bin": {
    "feishu-user-plugin": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "node src/test-all.js",
    "test:quick": "node src/test-send.js",
    "oauth": "node src/oauth.js"
  },
  "keywords": [
    "feishu",
    "lark",
    "claude-code",
    "plugin",
    "mcp",
    "model-context-protocol",
    "im",
    "messaging",
    "protobuf",
    "agent"
  ],
  "author": "EthanQC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EthanQC/feishu-user-plugin.git"
  },
  "homepage": "https://github.com/EthanQC/feishu-user-plugin#readme",
  "bugs": {
    "url": "https://github.com/EthanQC/feishu-user-plugin/issues"
  },
  "files": [
    "src/",
    "proto/",
    ".claude-plugin/",
    "skills/",
    ".mcp.json.example",
    ".env.example",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "protobufjs": "^7.4.0"
  }
}
