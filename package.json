{
  "name": "feishu-user-mcp",
  "version": "0.5.4",
  "description": "All-in-one Feishu/Lark MCP Server — 33 tools, 3 auth layers: user identity messaging (Protobuf), official API (REST), P2P chat reading (OAuth UAT).",
  "main": "src/index.js",
  "bin": {
    "feishu-user-mcp": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "node src/test-all.js",
    "test:quick": "node src/test-send.js",
    "oauth": "node src/oauth.js"
  },
  "keywords": [
    "feishu",
    "lark",
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "im",
    "messaging",
    "protobuf",
    "reverse-engineering"
  ],
  "author": "EthanQC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EthanQC/feishu-user-mcp.git"
  },
  "homepage": "https://github.com/EthanQC/feishu-user-mcp#readme",
  "bugs": {
    "url": "https://github.com/EthanQC/feishu-user-mcp/issues"
  },
  "files": [
    "src/",
    "proto/",
    ".env.example",
    "server.json",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "protobufjs": "^7.4.0"
  }
}
